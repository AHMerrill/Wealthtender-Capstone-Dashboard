# --- Wealthtender Dashboard environment variables ---
#
# Copy this file to .env and adjust values for your environment.
# For local development the defaults below should work out of the box.
# On Render, set these via the service's Environment tab (or render.yaml).

# Base URL of the FastAPI backend.
# Locally both services run on the same machine; on Render the API gets
# its own subdomain (e.g. https://wealthtender-api.onrender.com).
API_BASE=http://localhost:8000

# Port the dashboard listens on (Render injects this automatically).
PORT=8050

# Password for the Wealthtender Admin portal on the splash page.
# Set this on Render via the Environment tab.
ADMIN_PASSWORD=WT$msba2026
